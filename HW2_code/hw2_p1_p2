#!/usr/bin/env python3
"""
EE 5393 HW2
Stochastic simulations for Problems 1 and 2.

Problem 1:
    Gillespie-style SSA for the layered Fibonacci CRN.

Problem 2:
    Stochastic cycle-by-cycle biquad simulation.
    Each 1/8 branch is implemented as random binomial thinning,
    so each run is non-deterministic while the trial mean tracks
    the deterministic filter.
"""

from __future__ import annotations

import argparse
import random
from collections import defaultdict
from statistics import mean, pstdev
from typing import DefaultDict, List, Sequence, Tuple

import numpy as np


FibRow = Tuple[int, int, int, float, int]
BiquadRow = Tuple[int, int, int, int, int, int, int, int, int, int, int]


# ============================================================
# Problem 1: stochastic Fibonacci CRN
# ============================================================
def fibonacci_ssa(
    a0: int,
    b0: int,
    steps: int = 12,
    seed: int | None = None,
) -> Tuple[List[FibRow], float, int]:
    """
    Gillespie-style stochastic simulation for the layered CRN:
        A_i -> B_{i+1}
        B_i -> A_{i+1} + B_{i+1}

    Final counts are fixed by stoichiometry, but reaction order
    and completion times are random.
    """
    rng = random.Random(seed)

    counts: DefaultDict[str, int] = defaultdict(int)
    counts["A1"] = a0
    counts["B1"] = b0

    history: List[FibRow] = [(1, a0, b0, 0.0, 0)]
    t = 0.0
    fired = 0

    for i in range(1, steps):
        while counts[f"A{i}"] > 0 or counts[f"B{i}"] > 0:
            a_count = counts[f"A{i}"]
            b_count = counts[f"B{i}"]
            total_propensity = a_count + b_count

            if total_propensity <= 0:
                break

            t += rng.expovariate(total_propensity)

            if rng.random() * total_propensity < a_count:
                counts[f"A{i}"] -= 1
                counts[f"B{i+1}"] += 1
            else:
                counts[f"B{i}"] -= 1
                counts[f"A{i+1}"] += 1
                counts[f"B{i+1}"] += 1

            fired += 1

        history.append((i + 1, counts[f"A{i+1}"], counts[f"B{i+1}"], t, fired))

    return history, t, fired


def summarize_fibonacci_trials(
    a0: int,
    b0: int,
    trials: int = 1000,
    steps: int = 12,
) -> dict:
    times = []
    final_As = []
    final_Bs = []

    for seed in range(1, trials + 1):
        hist, t, _ = fibonacci_ssa(a0, b0, steps=steps, seed=seed)
        times.append(t)
        final_As.append(hist[-1][1])
        final_Bs.append(hist[-1][2])

    return {
        "final_A": final_As[0],
        "final_B": final_Bs[0],
        "time_mean": mean(times),
        "time_std": pstdev(times),
        "time_min": min(times),
        "time_max": max(times),
    }


def print_fib_table(history: Sequence[FibRow], label: str) -> None:
    print(label)
    print(f"{'Step':>4} {'A':>8} {'B':>8} {'time':>12} {'events':>8}")
    print("-" * 48)
    for step, a, b, t, fired in history:
        print(f"{step:>4} {a:>8} {b:>8} {t:>12.6f} {fired:>8}")
    print()


# ============================================================
# Problem 2: stochastic biquad
# ============================================================
def deterministic_biquad_reference(inputs: Sequence[int]) -> List[Tuple[int, float]]:
    """
    Deterministic reference equations:
        A_n = X_n + (1/8)S1_n + (1/8)S2_n
        Y_n = (1/8)A_n + (1/8)S1_n + (1/8)S2_n
        S1_{n+1} = A_n
        S2_{n+1} = S1_n
    """
    s1 = 0.0
    s2 = 0.0
    out = []

    for n, x in enumerate(inputs, start=1):
        a = x + s1 / 8.0 + s2 / 8.0
        y = a / 8.0 + s1 / 8.0 + s2 / 8.0
        out.append((n, y))
        s2, s1 = s1, a

    return out


def biquad_stochastic(
    inputs: Sequence[int],
    seed: int | None = None,
) -> Tuple[List[BiquadRow], Tuple[int, int]]:
    """
    Stochastic 5-cycle biquad simulation.

    Interpretation:
    - Each 1/8 weighted branch is modeled by binomial thinning.
    - If N molecules enter a 1/8 branch, the outgoing count is Binomial(N, 1/8).
    - After each cycle, Y is treated as sampled/cleared, while S1 and S2 are
      carried forward to the next cycle.

    Per cycle:
        F ~ Binomial(S1, 1/8)
        H ~ Binomial(S2, 1/8)
        A = X + F + H

        C ~ Binomial(A, 1/8)
        D ~ Binomial(S1, 1/8)
        E ~ Binomial(S2, 1/8)
        Y = C + D + E

        S2_next = S1
        S1_next = A
    """
    rng = np.random.default_rng(seed)

    s1 = 0
    s2 = 0
    rows: List[BiquadRow] = []

    for n, x in enumerate(inputs, start=1):
        f = int(rng.binomial(s1, 1 / 8))
        h = int(rng.binomial(s2, 1 / 8))
        a = x + f + h

        c = int(rng.binomial(a, 1 / 8))
        d = int(rng.binomial(s1, 1 / 8))
        e = int(rng.binomial(s2, 1 / 8))
        y = c + d + e

        rows.append((n, x, s1, s2, f, h, a, c, d, e, y))

        s2, s1 = s1, a

    return rows, (s1, s2)


def summarize_biquad_trials(
    inputs: Sequence[int],
    trials: int = 1000,
) -> List[dict]:
    ys = [[] for _ in inputs]

    for seed in range(1, trials + 1):
        rows, _ = biquad_stochastic(inputs, seed=seed)
        for i, row in enumerate(rows):
            ys[i].append(row[-1])

    out = []
    for i, vals in enumerate(ys, start=1):
        out.append(
            {
                "cycle": i,
                "mean": mean(vals),
                "std": pstdev(vals),
                "min": min(vals),
                "max": max(vals),
            }
        )
    return out


def print_biquad_table(rows: Sequence[BiquadRow]) -> None:
    print("Problem 2 sample stochastic run")
    print(f"{'cyc':>3} {'X':>5} {'S1':>5} {'S2':>5} {'F':>4} {'H':>4} {'A':>5} {'C':>4} {'D':>4} {'E':>4} {'Y':>5}")
    print("-" * 62)
    for row in rows:
        print(
            f"{row[0]:>3} {row[1]:>5} {row[2]:>5} {row[3]:>5} "
            f"{row[4]:>4} {row[5]:>4} {row[6]:>5} {row[7]:>4} "
            f"{row[8]:>4} {row[9]:>4} {row[10]:>5}"
        )
    print()


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--seed", type=int, default=5393, help="base seed")
    parser.add_argument("--trials", type=int, default=1000, help="number of trials")
    args = parser.parse_args()

    # ---------------- Problem 1 ----------------
    hist01, _, _ = fibonacci_ssa(0, 1, seed=args.seed)
    hist37, _, _ = fibonacci_ssa(3, 7, seed=args.seed + 1)

    print_fib_table(hist01, "Problem 1 sample stochastic run with initial state (0,1)")
    print_fib_table(hist37, "Problem 1 sample stochastic run with initial state (3,7)")

    stats01 = summarize_fibonacci_trials(0, 1, trials=args.trials)
    stats37 = summarize_fibonacci_trials(3, 7, trials=args.trials)

    print("Problem 1 multi-trial summary")
    print(
        f"(0,1) -> final (A12,B12)=({stats01['final_A']},{stats01['final_B']}), "
        f"time mean={stats01['time_mean']:.6f}, std={stats01['time_std']:.6f}, "
        f"min={stats01['time_min']:.6f}, max={stats01['time_max']:.6f}"
    )
    print(
        f"(3,7) -> final (A12,B12)=({stats37['final_A']},{stats37['final_B']}), "
        f"time mean={stats37['time_mean']:.6f}, std={stats37['time_std']:.6f}, "
        f"min={stats37['time_min']:.6f}, max={stats37['time_max']:.6f}"
    )
    print()

    # ---------------- Problem 2 ----------------
    inputs = [100, 5, 500, 20, 250]
    rows, final_state = biquad_stochastic(inputs, seed=args.seed)
    print_biquad_table(rows)
    print(f"Final stored state for next cycle: S1 = {final_state[0]}, S2 = {final_state[1]}")
    print()

    summary = summarize_biquad_trials(inputs, trials=args.trials)
    det = deterministic_biquad_reference(inputs)

    print("Problem 2 trial summary versus deterministic reference")
    print(f"{'cyc':>3} {'E[Y] approx':>12} {'std':>10} {'min':>6} {'max':>6} {'deterministic':>14}")
    print("-" * 58)
    for row, det_row in zip(summary, det):
        print(
            f"{row['cycle']:>3} {row['mean']:>12.3f} {row['std']:>10.3f} "
            f"{row['min']:>6} {row['max']:>6} {det_row[1]:>14.6f}"
        )


if __name__ == "__main__":
    main()
